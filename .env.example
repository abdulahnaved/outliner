# Required in production: at least 16 characters. Used to sign session cookies (JWT HS256).
OUTLINER_AUTH_SECRET=

# Optional (recommended for Vercel): Postgres connection string (e.g. Neon)
# If set, the Next.js app will store users + saved scans in Postgres instead of local SQLite.
# DATABASE_URL=

# Optional: override SQLite path (default: ./data/outliner.db)
# OUTLINER_DATABASE_PATH=

# Optional: Python scanner base URL (default: http://localhost:8000)
# OUTLINER_SCANNER_URL=
